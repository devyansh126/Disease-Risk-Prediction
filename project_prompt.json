  "predictor": {
    "class": "Predictor",
    "init": "Load all models + scalers + encoders once in __init__, not per request",
    "route_to_results_key_map": {
      "sleep": "sleep_apnea"
    },
    "predict_method": {
      "input": "disease (route key string), raw (dict of form values)",
      "output": {
        "prediction": "Predicted class label string",
        "probability": "Float percentage (0\u2013100) of predicted class",
        "risk_level": "low | moderate | high",
        "color": "Hex color string",
        "multiclass": "Boolean",
        "all_probs": "Dict of label \u2192 % \u2014 only present when multiclass=true"
      },
      "risk_thresholds": {
        "low": {
          "range": "< 30%",
          "color": "#00e5a0"
        },
        "moderate": {
          "range": "30\u201360%",
          "color": "#ff9500"
        },
        "high": {
          "range": "> 60%",
          "color": "#ff3b5c"
        }
      },
      "multiclass_probability": "Use argmax of predict_proba; probability = confidence of predicted class",
      "binary_probability": "Use predict_proba[:, 1]; apply saved threshold from pkl"
    },
    "preprocessing_per_disease": {
      "diabetes": "All numeric \u2014 direct float conversion, order matches feature_names list",
      "heart": "All numeric (selects already submit numeric string values) \u2014 direct float conversion",
      "obesity": "Load obesity_encoders.pkl, use LabelEncoder.transform() per categorical column, -1 for unseen values",
      "sleep_apnea": "Manual mapping for Gender/BMI Category/Occupation as defined in categorical_encoding above"
    }
  },
  "flask_routes": {
    "GET /": "Render index.html with HOME_CARDS list",
    "GET /<disease>": "Render form.html with cfg=DISEASE_CONFIG[disease] and stats=ALL_RESULTS.get(results_key)",
    "POST /predict/<disease>": "Return JSON from predictor.predict(disease, request.get_json())"
  },
  "all_results_json_schema": {
    "description": "Structure of results/all_results.json \u2014 generated by train.py, read at Flask startup",
    "top_level_keys": [
      "diabetes",
      "heart",
      "obesity",
      "sleep_apnea"
    ],
    "per_disease_fields": {
      "disease": "Display name string",
      "best_model": "Name of best model string",
      "accuracy": "Float %",
      "precision": "Float %",
      "recall": "Float %",
      "f1": "Float %",
      "roc_auc": "Float %",
      "cv_mean": "Float %",
      "cv_std": "Float %",
      "cv_f1_mean": "Float %",
      "silhouette": "Float",
      "threshold": "Float",
      "class_labels": "List of strings",
      "is_multiclass": "Boolean",
      "feature_names": "List of strings (may be absent for heart disease)",
      "all_models": {
        "description": "Dict of model_name \u2192 metrics",
        "per_model_fields": [
          "accuracy",
          "precision",
          "recall",
          "f1",
          "roc_auc",
          "cv_mean",
          "cv_std",
          "cv_f1_mean",
          "cv_f1_std"
        ]
      }
    }
  },
