{
  "project": {
    "name": "MedPredict \u2014 Multi-Disease Risk Prediction Web App",
    "description": "A machine learning pipeline that trains models for 4 diseases and serves a Flask web interface where patients enter medical values and receive risk predictions with percentage and color indicator.",
    "context": "2nd year B.Tech CSE college project",
    "run_command": "pip install flask && python app.py",
    "url": "http://localhost:5000"
  },
  "tech_stack": {
    "backend": "Flask (Python)",
    "frontend": "Plain HTML + CSS + Vanilla JS (no React, no Vue, no jQuery)",
    "ml": "scikit-learn + XGBoost \u2014 models loaded via pickle",
    "charts": "Chart.js 4.4.1 from cdnjs CDN",
    "database": "None required"
  },
  "folder_structure": {
    "app.py": "Flask routes + disease config dict",
    "predictor.py": "Model loading + prediction logic (loads all models once at startup)",
    "results/all_results.json": "Generated by train.py \u2014 read at startup",
    "models/": {
      "diabetes.pkl": "Best model + scaler + classes + threshold",
      "diabetes_scaler.pkl": "StandardScaler fitted on training data",
      "heart.pkl": "Best model + scaler + classes + threshold",
      "heart_scaler.pkl": "StandardScaler fitted on training data",
      "obesity.pkl": "Best model + scaler + classes + threshold",
      "obesity_scaler.pkl": "StandardScaler fitted on training data",
      "obesity_encoders.pkl": "Dict of LabelEncoder per categorical column",
      "sleep_apnea.pkl": "Best model + scaler + classes + threshold",
      "sleep_apnea_scaler.pkl": "StandardScaler fitted on training data"
    },
    "data/": "CSV files (already exists, not touched by app)",
    "templates/base.html": "Dark theme layout \u2014 navbar + footer",
    "templates/index.html": "Home page \u2014 hero + 4 disease cards + how it works",
    "templates/form.html": "Per-disease page \u2014 input form + result + stats panel",
    "static/style.css": "All styles \u2014 dark theme, animations, responsive",
    "static/script.js": "Form submit, validation, result render, chart"
  },
